{
	"name": "better-comments",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm -r --parallel --filter web --filter server dev",
		"build": "pnpm -r --if-present build",
		"check-types": "pnpm -r --if-present check-types",
		"dev:web": "pnpm --filter web dev",
		"dev:server": "pnpm --filter server dev",
		"db:push": "pnpm --filter @better-comments/db db:push",
		"db:studio": "pnpm --filter @better-comments/db db:studio",
		"db:generate": "pnpm --filter @better-comments/db db:generate",
		"db:migrate": "pnpm --filter @better-comments/db db:migrate",
		"db:local": "pnpm --filter @better-comments/db db:local",
		"check": "oxlint && oxfmt --write"
	},
  "dependencies": {
    "@better-comments/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-comments/config": "workspace:*",
		"@types/bun": "catalog:",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"typescript": "catalog:"
	},
  "packageManager": "pnpm@10.10.0"
}
